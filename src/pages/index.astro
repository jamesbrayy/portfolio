---
import Layout from '../components/layout.astro';
import Attractor from '../components/attractor.astro';
import ProjectCard from '../components/projectcard.astro';
import { projectsData } from '../data/projects.js';
---
<Layout title={`homepage \u2002 // \u2002 james bray`} >
  <section class="landing">
    <Attractor/>
    
    <div class="container">
      <p class="landing-label"><span>//</span> academic and project portfolio</p>
      <h1 class="landing-name" id="landing-name"><span class="cursor"></span></h1>
      <p class="landing-desc" id="landing-desc">
        Frontier Physics student at <em>The University of Western Australia</em>.
      </p>
      <div class="landing-meta" id="landing-meta">
        <div class="landing-stat">
          <label>specialisation</label>
          <value>experimental physics</value>
        </div>
        <div class="landing-stat">
          <label>level</label>
          <value>undergraduate</value>
        </div>
        <div class="landing-stat">
          <label>status</label>
          <value id="discord-status"><span style="color:#3a3a3a">●</span> loading...</value>
        </div>
      </div>
    </div>
    <button class="scroll-arrow" id="scroll-arrow" aria-label="Scroll to projects">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M4 7L10 13L16 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </section>

  <section id="projects">
    <div class="container">
      <div class="section-header">
        <span class="section-label">projects</span>
        <span class="section-title">selected work</span>
      </div>
      <div class="projects-grid">
        <ProjectCard 
          tag={projectsData["polar-imaging-cyberdeck"].tag}
          title={projectsData["polar-imaging-cyberdeck"].title}
          desc={projectsData["polar-imaging-cyberdeck"].desc}
          href="projects/polar-imaging-cyberdeck"
        />
        <ProjectCard 
          tag={projectsData["highly-inefficient-coil-gun"].tag}
          title={projectsData["highly-inefficient-coil-gun"].title}
          desc={projectsData["highly-inefficient-coil-gun"].desc}
          href="projects/highly-inefficient-coil-gun"
        />
        <ProjectCard 
          tag={projectsData["vapor-x5"].tag}
          title={projectsData["vapor-x5"].title}
          desc={projectsData["vapor-x5"].desc}
          href="projects/vapor-x5"
        />
        <ProjectCard 
          tag={projectsData["12kv-nst-spark-gap-tesla-coil"].tag}
          title={projectsData["12kv-nst-spark-gap-tesla-coil"].title}
          desc={projectsData["12kv-nst-spark-gap-tesla-coil"].desc}
          href="projects/12kv-nst-spark-gap-tesla-coil"
        />
        <ProjectCard 
          tag={projectsData["spring-damping-investigation"].tag}
          title={projectsData["spring-damping-investigation"].title}
          desc={projectsData["spring-damping-investigation"].desc}
          href="projects/spring-damping-investigation"
        />
        <ProjectCard 
          tag={projectsData["omnibot"].tag}
          title={projectsData["omnibot"].title}
          desc={projectsData["omnibot"].desc}
          href="projects/omnibot"
        />
      </div>
    </div>
  </section>

  <section id="education">
    <div class="container">
      <div class="section-header">
        <span class="section-label">education</span>
        <span class="section-title">academic history</span>
      </div>
      <div class="edu-list">

        <div class="edu-entry reveal">
          <div class="edu-meta">
            <span class="edu-period">Feb 2026 - Nov 2029</span>
            <span class="edu-status">in progress</span>
          </div>
          <div class="edu-body">
            <p class="edu-degree">Accelerated Bachelor of Science (Frontier Physics) and Master of Physics</p>
            <p class="edu-institution">The University of Western Australia</p>
            <div class="edu-stats">
              <div class="edu-stat">
                <label>wam</label>
                <value>83</value>
              </div>
              <div class="edu-stat">
                <label>gpa</label>
                <value>6.5</value>
              </div>
            </div>
            <div class="edu-subjects">
              <p class="edu-subjects-label">units taken</p>
              <div class="edu-subject-scroll-wrap">
                <button class="edu-scroll-btn left" aria-label="Scroll left">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M7.5 2L3.5 6L7.5 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <div class="edu-subject-scroll">
                  <span class="stack-tag">Multivariable Calculus (MATH1011)</span>
                  <span class="stack-tag">Mathematical Theory and Methods (MATH1012)</span>
                  <span class="stack-tag">Mathematical Analysis (MATH1013)</span>
                  <span class="stack-tag">Classical and Frontier Physics (PHYS1100)</span>
                </div>
                <button class="edu-scroll-btn right" aria-label="Scroll right">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M4.5 2L8.5 6L4.5 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="edu-entry reveal">
          <div class="edu-meta">
            <span class="edu-period">Feb 2020 - Nov 2025</span>
            <span class="edu-status">completed</span>
          </div>
          <div class="edu-body">
            <p class="edu-degree">Western Australian Certificate of Education (WACE)</p>
            <p class="edu-institution">Christ Church Grammar School</p>
            <div class="edu-stats">
              <div class="edu-stat">
                <label>atar</label>
                <value>99.40</value>
              </div>
            </div>
            <div class="edu-awards">
              <p class="edu-awards-label">achievements</p>
              <ul class="edu-award-list">
                <li><em>Engineering Studies Subject Exhibition</em> - Highest scoring student in Western Australia</li>
                <li><em>Australian Physics Olympiad (Distinction)</em> - Senior Division</li>
                <li><em>Australian Mathematics Competition (High Distinction)</em> - Senior Division</li>
                <li><em>ADF Future Innovators Award</em> - Built a custom PCB and mazebot control system from scratch</li>
                <li><em>Captain of Robotics</em> - Led team to two WA Winning FTC Alliance, Control and Design Awards</li>
                <li><em>The Duke of Edinburgh's Award (Silver)</em> - Contributions to music, sport, and community</li>
              </ul>
            </div>
            <div class="edu-subjects">
              <p class="edu-subjects-label">subjects</p>
              <div class="edu-subject-scroll-wrap">
                <button class="edu-scroll-btn left" aria-label="Scroll left">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M7.5 2L3.5 6L7.5 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <div class="edu-subject-scroll">
                  <span class="stack-tag">mathematics specialist</span>
                  <span class="stack-tag">mathematics methods</span>
                  <span class="stack-tag">physics</span>
                  <span class="stack-tag">engineering studies</span>
                  <span class="stack-tag">chemistry</span>
                  <span class="stack-tag">literature</span>
                </div>
                <button class="edu-scroll-btn right" aria-label="Scroll right">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M4.5 2L8.5 6L4.5 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="about">
    <div class="container">
      <div class="section-header">
        <span class="section-label">about</span>
        <span class="section-title">background</span>
      </div>
      <p class="about-text" id="about-text">
        I am a physics undergraduate with a strong focus on the <em>experimental</em> and <em>hands-on</em> aspects of the discipline. 
        While I value the theoretical framework of my studies, I am most passionate about validating and exploring predicted phenomena <em>at the bench</em>.
        <br><br>
        Outside of my university coursework, this manifests as a wide range of <em>self-driven projects</em>. I have designed and fabricated <em>high-voltage circuits</em>, 
        used <em>Python</em> to computationally model and visualise physical systems, and regularly build, fly, and repair high-performance <em>FPV quadcopters</em>. 
      </p>
      <div class="about-stack" id="about-stack">
        <span class="stack-tag">electromagnetism</span>
        <span class="stack-tag">signal processing</span>
        <span class="stack-tag">digital fabrication</span>
        <span class="stack-tag">fpv / control systems</span>
        <span class="stack-tag">python</span>
        <span class="stack-tag">latex</span>
      </div>
    </div>
  </section>

  <section id="contact">
    <div class="container">
      <div class="section-header">
        <span class="section-label">contact</span>
        <span class="section-title">get in touch</span>
      </div>
      <p class="contact-line" id="contact-line">
        Got an idea, question, or just want to talk physics - <a href="mailto:jamesmbray@outlook.com">jamesmbray@outlook.com</a>
      </p>
    </div>
  </section>
</Layout>

<script>
  const scrollArrow = document.getElementById('scroll-arrow');
  if (scrollArrow) {
    scrollArrow.addEventListener('click', () => {
      document.getElementById('projects')?.scrollIntoView({ behavior: 'smooth' });
    });
  }

  const DISCORD_ID = '783832796808478731';
  async function fetchDiscordPresence() {
    const statusEl = document.getElementById('discord-status');
    if (!statusEl) return;
    try {
      const response = await fetch(`https://api.lanyard.rest/v1/users/${DISCORD_ID}`);
      const { data } = await response.json();
      const statusMap = {
        online: { color: 'var(--accent)', text: 'online' },
        idle:   { color: 'var(--accent)', text: 'online' },
        dnd:    { color: '#ff4a4a',       text: 'busy' },
        offline:{ color: '#3a3a3a',       text: 'offline' }
      } as const;
      const currentStatus = data.discord_status as keyof typeof statusMap;
      const config = statusMap[currentStatus] || statusMap.offline;
      let activityText: string = config.text;
      if (data.activities && data.activities.length > 0) {
        const mainActivity = data.activities.find((act: any) => act.type !== 4);
        if (mainActivity) activityText = `${config.text} // ${mainActivity.name.toLowerCase()}`;
      }
      statusEl.innerHTML = `<span style="color:${config.color}">●</span> ${activityText}`;
    } catch {
      statusEl.innerHTML = `<span style="color:#ff4a4a">●</span> status error`;
    }
  }
  fetchDiscordPresence();
  setInterval(fetchDiscordPresence, 30000);

  const target = document.getElementById('landing-name');
  const text = 'James\nBray.';
  if (target) {
    const cursor = target.querySelector('.cursor');
    let i = 0;
    function type() {
      if (!target || !cursor) return;
      if (i < text.length) {
        const char = text[i];
        if (char === '\n') {
          target.insertBefore(document.createElement('br'), cursor);
        } else {
          const span = document.createElement('span');
          span.textContent = char;
          span.style.opacity = '0';
          span.style.transition = 'opacity 0.05s';
          target.insertBefore(span, cursor);
          requestAnimationFrame(() => { span.style.opacity = '1'; });
        }
        i++;
        setTimeout(type, i < 6 ? 80 : 55);
      } else {
        document.getElementById('landing-desc')?.classList.add('visible');
        document.getElementById('landing-meta')?.classList.add('visible');
        document.getElementById('scroll-arrow')?.classList.add('visible');
        const canvasEl = document.getElementById('attractor-canvas');
        if (canvasEl) {
          canvasEl.style.transition = 'opacity 3.0s cubic-bezier(0.25, 1, 0.5, 1)';
          canvasEl.style.opacity = '1';
        }
      }
    }
    setTimeout(type, 600);
  }

  document.querySelectorAll<HTMLElement>('.edu-subject-scroll-wrap').forEach(wrap => {
    const scroll  = wrap.querySelector<HTMLElement>('.edu-subject-scroll')!;
    const btnLeft = wrap.querySelector<HTMLElement>('.edu-scroll-btn.left')!;
    const btnRight= wrap.querySelector<HTMLElement>('.edu-scroll-btn.right')!;

    function updateBtns() {
      const atStart = scroll.scrollLeft <= 2;
      const atEnd   = scroll.scrollLeft >= scroll.scrollWidth - scroll.clientWidth - 2;
      btnLeft.classList.toggle('visible', !atStart);
      btnRight.classList.toggle('visible', !atEnd);
    }

    scroll.addEventListener('scroll', updateBtns, { passive: true });
    new ResizeObserver(updateBtns).observe(scroll);
    updateBtns();

    const STEP = 160;
    btnLeft.addEventListener('click',  () => scroll.scrollBy({ left: -STEP, behavior: 'smooth' }));
    btnRight.addEventListener('click', () => scroll.scrollBy({ left:  STEP, behavior: 'smooth' }));

    let isDown = false, startX = 0, startScroll = 0;
    scroll.addEventListener('mousedown', e => {
      isDown = true;
      startX = e.pageX;
      startScroll = scroll.scrollLeft;
      scroll.classList.add('dragging');
    });
    window.addEventListener('mouseup', () => {
      isDown = false;
      scroll.classList.remove('dragging');
    });
    scroll.addEventListener('mousemove', e => {
      if (!isDown) return;
      e.preventDefault();
      scroll.scrollLeft = startScroll - (e.pageX - startX);
    });

    scroll.addEventListener('wheel', e => {
      if (e.deltaY === 0) return;
      e.preventDefault();
      scroll.scrollBy({ left: e.deltaY * 1.5, behavior: 'smooth' });
    }, { passive: false });
  });
</script>

<style>
  .landing {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-bottom: 80px;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }
  .landing-label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted-text);
    margin-bottom: 24px;
  }
  .landing-label span { color: var(--accent); margin-right: 8px; }
  .landing-name {
    font-size: clamp(48px, 8vw, 88px);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text);
    overflow: hidden;
  }
  .landing-name :global(.cursor) {
    display: inline-block;
    width: 3px;
    height: 0.85em;
    background: var(--accent);
    margin-left: 4px;
    vertical-align: middle;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
  .landing-desc {
    margin-top: 40px;
    max-width: 600px;
    color: var(--muted-text);
    font-size: 14px;
    line-height: 1.8;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s 0.2s, transform 0.6s 0.2s;
  }
  .landing-desc.visible { opacity: 1; transform: none; }
  .landing-desc em { font-style: normal; color: var(--text); }
  .landing-meta {
    margin-top: 48px;
    display: flex;
    gap: 40px;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s 0.4s, transform 0.6s 0.4s;
  }
  .landing-meta.visible { opacity: 1; transform: none; }
  .landing-stat label {
    display: block;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted-text);
    margin-bottom: 4px;
  }
  .landing-stat value { font-size: 13px; color: var(--text); }

  section {
    padding: 96px 0;
    border-bottom: 1px solid var(--border);
    position: relative;
    background: var(--bg);
    z-index: 10;
  }
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 56px;
  }
  .section-label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .section-title {
    font-size: 13px;
    font-weight: 400;
    color: var(--muted-text);
  }
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .edu-list { display: flex; flex-direction: column; }
  .edu-entry {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 32px;
    padding: 40px 0;
    border-top: 1px solid var(--border);
  }
  .edu-entry:last-child { border-bottom: 1px solid var(--border); }
  .edu-meta { display: flex; flex-direction: column; gap: 8px; padding-top: 2px; }
  .edu-period {
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--muted-text);
    text-transform: uppercase;
  }
  .edu-status {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.7;
  }
  .edu-body { display: flex; flex-direction: column; gap: 6px; }
  .edu-degree {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0.01em;
  }
  .edu-institution {
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }
  .edu-stats {
    display: flex;
    gap: 32px;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }
  .edu-stat label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted-text);
    margin-bottom: 4px;
  }
  .edu-stat value { font-size: 13px; color: var(--text); }

  .edu-subjects { margin-top: 20px; }
  .edu-subjects-label {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted-text);
    margin-bottom: 10px;
  }
  .edu-subject-scroll-wrap {
    display: flex;
    align-items: center;
    position: relative;
    margin-left: 0;
    margin-right: 0;
  }
  .edu-scroll-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 100%;
    border: none;
    background: linear-gradient(to var(--direction, right), var(--bg) 60%, transparent);
    color: var(--muted-text);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: color 0.2s, opacity 0.15s;
    z-index: 2;
  }
  .edu-scroll-btn.left { left: 0; --direction: right; }
  .edu-scroll-btn.right { right: 0; --direction: left; }

  .edu-scroll-btn.visible {
    opacity: 1;
    pointer-events: auto;
  }
  .edu-scroll-btn:hover { color: var(--accent); }
  
  .edu-subject-scroll {
    flex: 1;
    display: flex;
    flex-wrap: nowrap;
    gap: 8px;
    overflow-x: scroll;
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
    user-select: none;
    border-left: none;
    border-right: none;
    padding: 4px 0; 
  }
  .edu-subject-scroll::-webkit-scrollbar { display: none; }
  .edu-subject-scroll.dragging { cursor: grabbing; }
  .edu-subject-scroll .stack-tag { flex-shrink: 0; }
  
  .edu-awards { margin-top: 20px; }
  .edu-awards-label {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted-text);
    margin-bottom: 10px;
  }
  .edu-award-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .edu-award-list li {
    font-size: 13px;
    color: var(--muted-text);
    padding-left: 16px;
    position: relative;
    line-height: 1.6;
  }
  .edu-award-list li::before {
    content: '-';
    position: absolute;
    left: 0;
    color: var(--text);
    opacity: 0.5;
  }
  .edu-award-list li em {
    font-style: normal;
    color: var(--text);
  }
  @media (max-width: 700px) {
    .edu-entry { grid-template-columns: 1fr; gap: 12px; }
    .edu-meta { flex-direction: row; gap: 16px; align-items: center; }
  }

  .about-text {
    font-size: 15px;
    color: var(--muted-text);
    line-height: 1.9;
    max-width: 1000px;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s, transform 0.6s;
  }
  .about-text.visible { opacity: 1; transform: none; }
  .about-text em { font-style: normal; color: var(--text); }
  .about-stack {
    margin-top: 48px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s 0.2s, transform 0.6s 0.2s;
  }
  .about-stack.visible { opacity: 1; transform: none; }
  .stack-tag {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-text);
    border: 1px solid var(--border);
    padding: 6px 12px;
  }

  .contact-line {
    font-size: clamp(22px, 4vw, 36px);
    font-weight: 300;
    color: var(--muted-text);
    line-height: 1.5;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s, transform 0.6s;
  }
  .contact-line.visible { opacity: 1; transform: none; }
  .contact-line a {
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
    transition: color 0.2s;
  }
  .contact-line a:hover { color: var(--accent); }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s, transform 0.6s;
  }
  .reveal.visible { opacity: 1; transform: none; }

  @media (max-width: 600px) {
    .projects-grid { grid-template-columns: 1fr; }
    .landing-meta { flex-wrap: wrap; gap: 24px; }
  }

  .scroll-arrow {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(0);
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(12, 12, 12, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    color: var(--muted-text);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.6s 1.2s, color 0.2s, border-color 0.2s, transform 0.3s ease;
  }
  .scroll-arrow.visible { opacity: 1; }
  .scroll-arrow:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateX(-50%) translateY(5px);
  }
</style>