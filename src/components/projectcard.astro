---
interface Props {
  tag: string;
  title: string;
  desc: string;
  href: string;
}

const { tag, title, desc, href } = Astro.props;
---

<a href={href} class="project-card" transition:animate="slide">
  <p class="project-tag">{tag}</p>
  <h2 class="project-title">{title}</h2>
  <p class="project-desc">{desc}</p>
  <p class="project-arrow">view project →</p>
</a>

<style>
  .project-card {
    background: var(--bg);
    padding: 32px;
    cursor: pointer;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s, transform 0.5s, background 0.2s;
    text-decoration: none;
    display: block;
    color: inherit;
  }
  
  .project-card:global(.visible) {
    opacity: 1;
    transform: none;
  }

  .project-card:hover { 
    background: #111; 
  }
  
  .project-tag {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted-text);
    margin-bottom: 16px;
  }
  
  .project-title {
    font-size: 17px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 12px;
    line-height: 1.3;
  }
  
  .project-desc {
    font-size: 13px;
    color: var(--muted-text);
    line-height: 1.7;
  }
  
  .project-arrow {
    margin-top: 24px;
    font-size: 12px;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.2s;
  }
  
  .project-card:hover .project-arrow { 
    opacity: 1; 
  }
</style>